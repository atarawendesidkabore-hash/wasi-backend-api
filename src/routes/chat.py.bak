"""
Chat proxy — forwards messages to the Anthropic Claude API server-side,
so the API key is never exposed to the browser.
"""
from fastapi import APIRouter, Depends, HTTPException
from pydantic import BaseModel
from typing import Optional
import httpx

from src.database.models import User
from src.utils.security import get_current_user
from src.config import settings

router = APIRouter(prefix="/api/chat", tags=["Chat"])

ANTHROPIC_API_URL = "https://api.anthropic.com/v1/messages"
ANTHROPIC_VERSION = "2023-06-01"


class ChatMessage(BaseModel):
    role: str
    content: str


class ChatRequest(BaseModel):
    model: str = "claude-haiku-4-5-20251001"
    max_tokens: int = 1000
    system: Optional[str] = None
    messages: list[ChatMessage]


@router.post("")
async def proxy_chat(
    payload: ChatRequest,
    current_user: User = Depends(get_current_user),
):
    """
    Proxy to Anthropic Claude API. Keeps the API key server-side.
    Requires authentication — no credit charge (chat is billed by Anthropic directly).
    """
    if not settings.ANTHROPIC_API_KEY:
        raise HTTPException(
            status_code=503,
            detail="ANTHROPIC_API_KEY not configured on this server.",
        )

    body = {
        "model": payload.model,
        "max_tokens": payload.max_tokens,
        "messages": [{"role": m.role, "content": m.content} for m in payload.messages],
    }
    if payload.system:
        body["system"] = payload.system

    async with httpx.AsyncClient(timeout=60.0) as client:
        try:
            resp = await client.post(
                ANTHROPIC_API_URL,
                headers={
                    "x-api-key": settings.ANTHROPIC_API_KEY,
                    "anthropic-version": ANTHROPIC_VERSION,
                    "content-type": "application/json",
                },
                json=body,
            )
        except httpx.RequestError as exc:
            raise HTTPException(status_code=502, detail=f"Upstream request failed: {exc}")

    if resp.status_code != 200:
        raise HTTPException(status_code=resp.status_code, detail=resp.text)

    return resp.json()
